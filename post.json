  {
    "info": {                                                                                                                                                                                                                                               "name": "Grok2API - Video",
      "_postman_id": "grok2api-video-v1",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      { "key": "base_url", "value": "http://localhost:8000" },
      { "key": "api_key",  "value": "sk-xxxxxxxx" }
    ],
    "item": [
      {
        "name": "创建视频 (grok-video-3, 6s, 竖屏)",
        "request": {
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{api_key}}" }
          ],
          "body": {
            "mode": "formdata",
            "formdata": [
              { "key": "model",        "value": "grok-video-3", "type": "text" },
              { "key": "prompt",       "value": "猫咪听歌摇头晃脑，下大雨", "type": "text" },
              { "key": "aspect_ratio", "value": "2:3",  "type": "text" },
              { "key": "size",         "value": "720P", "type": "text" }
            ]
          },
          "url": { "raw": "{{base_url}}/v1/videos", "host": ["{{base_url}}"], "path": ["v1","videos"] }
        }
      },
      {
        "name": "创建视频 (grok-video-3-10s, 10s, 横屏, 1080P)",
        "request": {
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{api_key}}" }
          ],
          "body": {
            "mode": "formdata",
            "formdata": [
              { "key": "model",        "value": "grok-video-3-10s", "type": "text" },
              { "key": "prompt",       "value": "日落时分海浪拍打礁石", "type": "text" },
              { "key": "aspect_ratio", "value": "3:2",   "type": "text" },
              { "key": "size",         "value": "1080P", "type": "text" }
            ]
          },
          "url": { "raw": "{{base_url}}/v1/videos", "host": ["{{base_url}}"], "path": ["v1","videos"] }
        }
      },
      {
        "name": "创建视频 (带参考图)",
        "request": {
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{api_key}}" }
          ],
          "body": {
            "mode": "formdata",
            "formdata": [
              { "key": "model",           "value": "grok-video-3",  "type": "text" },
              { "key": "prompt",          "value": "让图中的猫咪动起来", "type": "text" },
              { "key": "aspect_ratio",    "value": "1:1",  "type": "text" },
              { "key": "size",            "value": "720P", "type": "text" },
              { "key": "input_reference", "src":   "/path/to/ref.jpg", "type": "file" }
            ]
          },
          "url": { "raw": "{{base_url}}/v1/videos", "host": ["{{base_url}}"], "path": ["v1","videos"] }
        }
      },
      {
        "name": "查询视频状态",
        "request": {
          "method": "GET",
          "header": [
            { "key": "Authorization", "value": "Bearer {{api_key}}" }
          ],
          "url": {
            "raw":  "{{base_url}}/v1/videos/{{video_id}}",
            "host": ["{{base_url}}"],
            "path": ["v1","videos","{{video_id}}"]
          }
        }
      },
      {
        "name": "下载视频内容",
        "request": {
          "method": "GET",
          "header": [
            { "key": "Authorization", "value": "Bearer {{api_key}}" }
          ],
          "url": {
            "raw":  "{{base_url}}/v1/videos/{{video_id}}/content",
            "host": ["{{base_url}}"],
            "path": ["v1","videos","{{video_id}}","content"]
          }
        }
      }
    ]
  }